<?xml version="1.0" encoding="utf-8"?>
<schemalist>
  <schema id="me.acristoffers.void" path="/me/acristoffers/void/">
    <key name="use-system" type="b">
      <default>true</default>
      <summary>Use system theme</summary>
    </key>
    <key name="dark-theme" type="b">
      <default>true</default>
      <summary>Use dark theme</summary>
    </key>
    <key name="icon-size" type="i">
      <default>48</default>
      <summary>Icon size in the grid view</summary>
    </key>
    <key name="sort-order" type="s">
      <default>'az'</default>
      <summary>Sort order in the grid view (az or za)</summary>
    </key>
  </schema>
</schemalist>
